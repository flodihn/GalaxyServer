{deps, [
    {holonet_srv, {path, "../holonet_srv"}}
]}.

{erl_opts, [
	{i, "../galaxy_srv/include/"},
	{i, "../resource_srv/include/"},
	{i, "../battle_srv/include/"},
	{d, 'ACCEPTOR_POOL_SIZE', 50}
]}.

{edoc_opts, [{dir, "api_docs/"}, {source_path, ["src/"]}]}.

{eunit_opts, [
	verbose,
	{report, {eunit_surefire, [{dir, "."}]}}
]}.

{eunit_compile_opts, []}.

{shell, [
	{config, "config/dev.config"},
	{apps, [sws_srv, holonet_srv]}
]}.

