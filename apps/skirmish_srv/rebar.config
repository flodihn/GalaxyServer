{deps, [
    battle_rules
]}.

{profiles,
    [{test, [
        {deps, [
            {meck, ".*",
                {git, "https://github.com/eproxus/meck.git", "master"}}
        ]}
    ]}]
}.

{erl_opts, []}.

{edoc_opts, [
    {dir, "api_docs/"}
]}.

{cover_enabled, true}.
{cover_print_enabled, true}.
{cover_export_enabled, false}.
{cover_opts, [verbose]}.

{eunit_opts, [
    verbose,
    {report, {eunit_surefire, [{dir, "."}]}}]}.

{eunit_compile_opts, []}.
